# apps/web 로컬 개발 환경변수. 이 파일을 apps/web/.env.local 로 복사한 뒤 값을 채운다.
# .env.local 은 .gitignore 대상(커밋 금지). 값 출처는 아래 주석 참조.

# Supabase 프로젝트(대시보드 Settings > API). 클라이언트 노출 가능.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# GitHub 잔디/이슈용 Personal Access Token. 서버 전용.
GITHUB_TOKEN=

# Gemini API 키(Google AI Studio, 무료 티어). RAG·에이전트·에디터 AI 작문 보조(/api/ai/write) 모두 사용. 서버 전용.
GEMINI_API_KEY=

# (선택) 뉴스 수집 스케줄 엔드포인트 보호용 시크릿. 로컬 개발엔 없어도 동작.
CRON_SECRET=
