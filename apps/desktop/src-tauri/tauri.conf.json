{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Little Dev Duck",
  "version": "0.1.0",
  "identifier": "dev.littledevduck.desktop",
  "build": {
    "frontendDist": "https://web-sepia-one-88.vercel.app",
    "devUrl": "https://web-sepia-one-88.vercel.app"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Little Dev Duck",
        "width": 360,
        "height": 640,
        "resizable": true,
        "fullscreen": false,
        "alwaysOnTop": true
      },
      {
        "label": "walker",
        "title": "Little Dev Duck — 활보",
        "url": "/walker",
        "width": 1280,
        "height": 800,
        "maximized": true,
        "resizable": false,
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
